  "benchmark_cases": [
    {
      "inn": "ibuprofen",
      "category": ["simple", "multi_context"],
      "use_case": "ra_regulatory_screening",
      "description": "OTC NSAID, registered globally, multiple forms/routes, well-studied",
      "must_find_docs": [
        {"source": "openfda", "doc_kind": "label"},
        {"source": "ema_smpc", "doc_kind": "smpc"},
        {"source": "grls", "doc_kind": "grls_card"},
        {"source": "ctgov", "doc_kind": "ctgov"},
        {"source": "epo_ops", "doc_kind": "patent"},
        {"source": "pubchem", "doc_kind": "pubchem"}
      ],
      "must_fill_fields": [
        "passport.chemical_formula",
        "passport.mechanism_of_action",
        "passport.route_of_administration",
        "passport.dosage_forms",
        "passport.trade_names",
        "registrations.US.status",
        "registrations.EU.status",
        "registrations.RU.status"
      ],
      "expected_decision_readiness": {
        "registrations": "ready",
        "clinical": "ready",
        "patents": "partial",
        "chemistry": "ready"
      },
      "known_limitations": [
        "EAEU portal not implemented",
        "OCR disabled for RU instruction PDFs"
      ],
      "must_not_mix_contexts": true
    },
