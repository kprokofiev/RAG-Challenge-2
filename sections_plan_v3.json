  "dossier_clinical_studies": {
    "section_id": "dossier_clinical_studies",
    "title": "Clinical Studies (Structured Cards)",
    "authority_scope": "CLINICAL",
    "dossier_target": "clinical_studies",
    "tier_1_doc_kinds": ["ctgov_protocol", "ctgov_results", "ctgov", "trial_registry", "scientific_pmc", "scientific_pdf", "publication"],
    "questions": [
      {
        "scope": "CLINICAL_US",
        "question": "For each pivotal phase 3 trial: extract NCT ID, trial name, phase, study type (RCT/non-RCT/obs), enrollment N, countries, comparator arm, dosing regimen, primary endpoint result (value + p-value + CI), and conclusion.",
        "answer_type": "table",
        "doc_kind_preference": ["ctgov_protocol", "ctgov_results", "ctgov"],
        "focus_terms": ["NCT", "phase 3", "randomized", "enrollment", "comparator", "primary endpoint", "p-value", "hazard ratio", "odds ratio", "countries", "conclusion"]
      },
      {
        "scope": "CLINICAL_US",
        "question": "For each phase 2 trial: extract NCT ID, trial name, phase, N, comparator, dosing, key efficacy finding.",
        "answer_type": "table",
        "doc_kind_preference": ["ctgov_protocol", "ctgov_results", "ctgov"],
        "focus_terms": ["NCT", "phase 2", "dose-finding", "enrollment", "comparator", "efficacy", "dose", "safety"]
      },
      {
        "scope": "PUBLICATIONS",
        "question": "What clinical studies are reported in peer-reviewed publications? Extract study design, N, comparator, primary endpoint result, and conclusion for each publication.",
        "answer_type": "facts",
        "doc_kind_preference": ["scientific_pmc", "scientific_pdf", "publication"],
        "focus_terms": ["randomized controlled trial", "clinical trial", "enrollment", "primary endpoint", "efficacy", "comparator", "N=", "treatment effect", "HR", "OR", "RR"]
      }
    ]
  },

  "dossier_patent_families": {
    "section_id": "dossier_patent_families",
    "title": "Patent Families (INPADOC + RU)",
    "authority_scope": "PATENTS",
    "dossier_target": "patent_families",
    "tier_1_doc_kinds": ["patent_family", "ops", "patent_pdf", "ru_patent_fips", "patent"],
    "questions": [
      {
        "scope": "PATENTS",
        "question": "What compound/composition patent families cover the active ingredient? For each family: representative pub number, priority date, assignee, expiry estimate, country coverage, what it protects.",
        "answer_type": "facts",
        "doc_kind_preference": ["patent_family", "ops", "patent_pdf"],
        "focus_terms": ["compound patent", "composition", "active ingredient", "priority date", "expiry", "assignee", "EP", "WO", "US patent", "jurisdiction", "country", "family"]
      },
      {
        "scope": "PATENTS",
        "question": "What formulation, method-of-use, or process patents exist? For each: representative number, priority date, what it blocks (formulation / method of treatment / synthesis process), country coverage.",
        "answer_type": "facts",
        "doc_kind_preference": ["patent_family", "ops", "patent_pdf"],
        "focus_terms": ["formulation patent", "use patent", "method of treatment", "process patent", "polymorph", "crystalline", "delivery", "dosage form", "ANDA barrier"]
      },
      {
        "scope": "PATENTS",
        "question": "What Russian/EAPO patents exist (from Rospatent/FIPS data)? For each: registration number, priority date, assignee, title summary.",
        "answer_type": "facts",
        "doc_kind_preference": ["ru_patent_fips", "patent_pdf", "patent"],
        "focus_terms": ["патент", "Роспатент", "приоритет", "заявитель", "assignee", "EAPO", "EA patent", "RU patent", "priority"]
      },
      {
        "scope": "PATENTS",
        "question": "What are the SPC (supplementary protection certificate) grants or lapses, and patent cliff estimates?",
        "answer_type": "numbers",
        "doc_kind_preference": ["patent_family", "ops"],
        "focus_terms": ["SPC", "supplementary protection certificate", "patent cliff", "expiry date", "term extension", "lapse", "grant"]
      }
    ]
  },

  "dossier_synthesis": {
    "section_id": "dossier_synthesis",
    "title": "Synthesis & Chemistry (from Patents)",
    "authority_scope": "CHEMISTRY",
    "dossier_target": "synthesis_steps",
    "tier_1_doc_kinds": ["patent_pdf", "drug_monograph", "patent"],
    "questions": [
      {
        "scope": "CHEMISTRY",
        "question": "What synthesis routes are described in patent documents? Extract each step with: step number, description, starting materials/reagents, intermediates, yield (if stated).",
        "answer_type": "facts",
        "doc_kind_preference": ["patent_pdf", "patent"],
        "focus_terms": ["synthesis", "route", "step", "starting material", "reagent", "intermediate", "reaction", "yield", "Example 1", "preparation", "method"]
      },
      {
        "scope": "CHEMISTRY",
        "question": "What manufacturing processes or API synthesis methods are described in drug monographs or patents?",
        "answer_type": "facts",
        "doc_kind_preference": ["drug_monograph", "patent_pdf"],
        "focus_terms": ["manufacturing", "API synthesis", "process", "batch", "active pharmaceutical ingredient", "production", "GMP"]
      }
    ]
  }
