        "doc_kind_preference": ["grls_card", "grls"],
        "focus_terms": ["регистрационный номер", "дата регистрации", "держатель", "статус", "форма выпуска", "торговое наименование", "действующий", "registration", "status", "MAH", "form", "strength"]
