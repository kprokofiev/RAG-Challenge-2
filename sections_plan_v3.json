{
  "_meta": {
    "sections_plan_version": "3.0",
    "description": "Dossier-oriented sections plan v3.0. Produces DossierReport v3.0 schema: passport + registrations + clinical_studies + patent_families + synthesis_steps + unknowns + evidence_registry. Every field requires evidence or goes to unknowns with typed reason_code.",
    "changelog": [
      "3.0 (Sprint 4): Full dossier schema extraction — passport, registrations (RU/EU/US), clinical study cards, patent families (INPADOC+RU), synthesis steps. All questions designed to extract structured EvidencedValue objects."
    ]
  },

  "dossier_passport": {
    "section_id": "dossier_passport",
    "title": "Drug Passport",
    "authority_scope": "PASSPORT",
    "dossier_target": "passport",
    "tier_1_doc_kinds": ["label", "us_fda", "epar", "smpc", "grls_card", "grls", "drug_monograph"],
    "questions": [
      {
        "scope": "US_REG",
        "question": "What is the INN, trade names, FDA NDA/BLA number, approval date, indication, and sponsor?",
        "answer_type": "facts",
        "doc_kind_preference": ["label", "us_fda", "approval_letter"],
        "focus_terms": ["INN", "trade name", "brand name", "NDA", "BLA", "approval date", "indication", "sponsor", "applicant"]
      },
      {
        "scope": "EU_REG",
        "question": "What is the EMA marketing authorization number, MAH, and approved indication per EPAR?",
        "answer_type": "facts",
        "doc_kind_preference": ["epar", "smpc", "assessment_report"],
        "focus_terms": ["marketing authorisation", "MAH", "indication", "approval date", "EU/H/C"]
      },
      {
        "scope": "RU_REG",
        "question": "What is the GRLS registration number, MAH, approved trade names and registration date?",
        "answer_type": "facts",
        "doc_kind_preference": ["grls_card", "grls", "ru_instruction"],
        "focus_terms": ["регистрационный номер", "МНН", "торговое наименование", "держатель", "дата", "registration number", "trade name", "holder"]
      },
      {
        "scope": "CHEMISTRY",
        "question": "What is the molecular formula, drug class, ATC code, and mechanism of action?",
        "answer_type": "facts",
        "doc_kind_preference": ["drug_monograph", "label", "smpc", "epar"],
        "focus_terms": ["formula", "molecular weight", "ATC", "drug class", "mechanism of action", "pharmacology", "MoA", "target"]
      },
      {
        "scope": "US_REG",
        "question": "What routes of administration, dosage forms, and key approved dosing regimens are listed?",
        "answer_type": "facts",
        "doc_kind_preference": ["label", "us_fda", "smpc", "ru_instruction"],
        "focus_terms": ["route of administration", "dosage form", "dose", "regimen", "tablet", "mg", "injection", "oral", "subcutaneous"]
      }
    ]
  },

